# SQLite database path
DATABASE_URL=sqlite+aiosqlite:///./arypodr.db

# Public base URL of this Arypodr instance.
# Used to build local feed and media URLs returned to AntennaPod.
# Example: http://192.168.1.10:8000  or  https://arypodr.home.arpa
BASE_URL=http://localhost:8000

# Directory where audio files are stored on disk.
# Must be writable by the Arypodr process.
MEDIA_PATH=/podcasts

# Enable SQLAlchemy query logging and FastAPI debug mode
DEBUG=false
